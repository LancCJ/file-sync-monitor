        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "詳情與快捷操作"
          }
        }
      }
    },
    "选中记录后可查看路径、时间、状态，并执行同步、标记完成、Finder 显示或删除记录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select a record to view path, time, status, and run sync, mark done, show in Finder, or delete."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选中记录后可查看路径、时间、状态，并执行同步、标记完成、Finder 显示或删除记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選中記錄後可查看路徑、時間、狀態，並執行同步、標記完成、Finder 顯示或刪除記錄。"
          }
        }
      }
    },
    "批量删除记录": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Batch Delete Records"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "批量删除记录"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "批次刪除記錄"
          }
        }
      }
    },
    "在待同步或全部记录页可清理当前筛选结果，只删除应用内记录，不影响真实文件。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clean the current filtered result in Pending or All Records. This only removes app records, not real files."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在待同步或全部记录页可清理当前筛选结果，只删除应用内记录，不影响真实文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在待同步或全部記錄頁可清理目前篩選結果，只刪除應用內記錄，不影響真實檔案。"
          }
        }
      }
    },
    "IMA 云端同步": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "IMA Cloud Sync"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "IMA 云端同步"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "IMA 雲端同步"
          }
        }
      }
    },
    "支持手动上传、自动上传、知识库绑定和云端拉取。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Supports manual upload, auto upload, knowledge-base binding, and cloud pull."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "支持手动上传、自动上传、知识库绑定和云端拉取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "支援手動上傳、自動上傳、知識庫綁定和雲端拉取。"
          }
        }
      }
    },
    "默认采用手动模式，点击单条“同步到 IMA”或首页“全部同步”后再上传。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manual mode is the default. Upload by clicking Sync to IMA on one item or Sync All on Home."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认采用手动模式，点击单条“同步到 IMA”或首页“全部同步”后再上传。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "預設採用手動模式，點擊單筆「同步到 IMA」或首頁「全部同步」後再上傳。"
          }
        }
      }
    },
    "开启后，文件稳定 30 秒会自动上传，减少频繁保存造成的重复同步。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, files upload after staying stable for 30 seconds, reducing duplicate syncs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后，文件稳定 30 秒会自动上传，减少频繁保存造成的重复同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，檔案穩定 30 秒會自動上傳，減少頻繁保存造成的重複同步。"
          }
        }
      }
    },
    "目录绑定知识库": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bind Folders to Knowledge Bases"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目录绑定知识库"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目錄綁定知識庫"
          }
        }
      }
    },
    "每个监控目录都可以绑定不同 IMA 知识库；不绑定时默认导入为新笔记。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each monitored folder can bind to a different IMA knowledge base; unbound folders import as new notes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个监控目录都可以绑定不同 IMA 知识库；不绑定时默认导入为新笔记。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每個監控目錄都可以綁定不同 IMA 知識庫；不綁定時預設匯入為新筆記。"
          }
        }
      }
    },
    "待同步页可从 IMA 拉取云端新增内容，并下载到对应本地目录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Pending page can pull new IMA cloud content and download it to the matching local folder."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "待同步页可从 IMA 拉取云端新增内容，并下载到对应本地目录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "待同步頁可從 IMA 拉取雲端新增內容，並下載到對應本地目錄。"
          }
        }
      }
    },
    "删除事件同步提示": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletion Sync Notice"
          }
        },
        "zh-Hans": {
