          "stringUnit": {
            "state": "translated",
            "value": "清新、輕量、面向日常同步工作流。"
          }
        }
      }
    },
    "本工具用于监控本地文件变动，并辅助同步到 IMA 云端。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This tool monitors local file changes and helps sync them to IMA Cloud."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本工具用于监控本地文件变动，并辅助同步到 IMA 云端。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本工具用於監控本地檔案變動，並輔助同步到 IMA 雲端。"
          }
        }
      }
    },
    "监控与过滤": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitoring & Filtering"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "监控与过滤"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "監控與過濾"
          }
        }
      }
    },
    "从选择目录到过滤噪声文件，保证记录列表干净可用。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From folder selection to noise filtering, keep your records clean and useful."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从选择目录到过滤噪声文件，保证记录列表干净可用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從選擇目錄到過濾雜訊檔案，保證記錄列表乾淨可用。"
          }
        }
      }
    },
    "添加监控目录": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add Monitored Folders"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加监控目录"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增監控目錄"
          }
        }
      }
    },
    "在首页或设置中添加文件夹，应用会保存授权并在下次启动后继续监控。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add folders from Home or Settings. The app saves permission and keeps monitoring after restart."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在首页或设置中添加文件夹，应用会保存授权并在下次启动后继续监控。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在首頁或設定中新增資料夾，應用會保存授權並在下次啟動後繼續監控。"
          }
        }
      }
    },
    "实时捕获变动": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Capture Changes in Real Time"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "实时捕获变动"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即時捕獲變動"
          }
        }
      }
    },
    "通过 macOS FSEvents 捕获新增、修改、删除和重命名，变动会自动进入记录列表。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uses macOS FSEvents to capture created, modified, deleted, and renamed files automatically."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 macOS FSEvents 捕获新增、修改、删除和重命名，变动会自动进入记录列表。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過 macOS FSEvents 捕獲新增、修改、刪除和重新命名，變動會自動進入記錄列表。"
          }
        }
      }
    },
