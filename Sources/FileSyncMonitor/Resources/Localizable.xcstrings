            "state": "translated",
            "value": "支持开源项目"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "支持開源專案"
          }
        }
      }
    },
    "FileSyncMonitor 将以开源方式提供。如果它帮你节省了时间，欢迎扫码捐赠支持后续维护。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "FileSyncMonitor will be provided as open source. If it saves you time, scan a QR code to support ongoing maintenance."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "FileSyncMonitor 将以开源方式提供。如果它帮你节省了时间，欢迎扫码捐赠支持后续维护。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "FileSyncMonitor 將以開源方式提供。如果它幫你節省了時間，歡迎掃碼捐贈支持後續維護。"
          }
        }
      }
    },
    "微信捐赠": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WeChat Donation"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "微信捐赠"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "微信捐贈"
          }
        }
      }
    },
    "支付宝捐赠": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alipay Donation"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "支付宝捐赠"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "支付寶捐贈"
          }
        }
      }
    },
    "捐赠说明": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Donation Notes"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "捐赠说明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "捐贈說明"
          }
        }
      }
    },
    "捐赠完全自愿，不影响任何功能使用。感谢每一份支持，它会用于持续适配 macOS、维护 IMA 同步能力和完善文档。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Donations are fully optional and do not affect any features. Every contribution helps with macOS compatibility, IMA sync maintenance, and documentation."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "捐赠完全自愿，不影响任何功能使用。感谢每一份支持，它会用于持续适配 macOS、维护 IMA 同步能力和完善文档。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "捐贈完全自願，不影響任何功能使用。感謝每一份支持，它會用於持續適配 macOS、維護 IMA 同步能力和完善文件。"
          }
        }
      }
    },
    "让界面语言、外观与凭据配置保持可控。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep language, appearance, and credentials under control."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "让界面语言、外观与凭据配置保持可控。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓介面語言、外觀與憑證配置保持可控。"
          }
        }
      }
    },
    "本地操作同步逻辑": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Operation Sync Logic"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本地操作同步邏輯"
          }
        }
      }
    },
    "理解每种文件操作会如何进入待同步列表、自动同步和历史记录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Understand how each file operation enters pending sync, auto sync, and history."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "理解每種文件操作會如何進入待同步列表、自動同步和歷史記錄。"
          }
        }
      }
    },
    "本地操作": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Operation"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本地操作"
          }
        }
      }
    },
    "记录类型": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Record Type"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記錄類型"
          }
        }
      }
    },
    "同步处理": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync Handling"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "同步處理"
          }
        }
      }
    },
    "用户需要知道": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What to Know"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用者需要知道"
          }
        }
      }
    },
    "新增文件": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New File"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增文件"
          }
        }
      }
    },
    "生成一条待同步记录；手动模式等待点击同步，自动模式在文件稳定 30 秒后上传。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creates one pending record. Manual mode waits for you to sync; auto mode uploads after the file is stable for 30 seconds."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "產生一條待同步記錄；手動模式等待點擊同步，自動模式在文件穩定 30 秒後上傳。"
          }
        }
      }
    },
    "如果新建后又立即删除，应用会抵消这次短暂变动，不再产生待同步事项。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the file is created and then deleted immediately, the app cancels that short-lived change and creates no pending item."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果新建後又立即刪除，應用會抵消這次短暫變動，不再產生待同步事項。"
          }
        }
      }
    },
    "修改文件": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Modified File"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "修改文件"
          }
        }
      }
    },
    "同一路径已有未同步记录时只更新时间，避免反复保存产生多条记录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When the same path already has an unsynced record, only the timestamp is refreshed to avoid repeated save noise."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "同一路徑已有未同步記錄時只更新時間，避免反覆儲存產生多條記錄。"
          }
        }
      }
    },
    "自动同步会在最后一次修改后重新等待 30 秒。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto sync waits another 30 seconds after the last modification."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動同步會在最後一次修改後重新等待 30 秒。"
          }
        }
      }
    },
    "删除文件": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleted File"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除文件"
          }
        }
      }
    },
    "删除会生成删除记录；同步时仅在本地标记完成。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletion creates a deleted record. Syncing marks it complete locally."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除會產生刪除記錄；同步時僅在本地標記完成。"
          }
        }
      }
    },
    "当前 IMA 未开放云端删除接口，云端已有文档需要用户按需手动清理。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "IMA currently does not provide a cloud deletion API, so existing cloud documents need to be cleaned manually when needed."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "目前 IMA 未開放雲端刪除接口，雲端已有文件需要使用者按需手動清理。"
          }
        }
      }
    },
    "重命名文件": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Renamed File"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重新命名文件"
          }
        }
      }
    },
    "已存在文件重命名会生成重命名记录，并在详情里保留原路径。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Renaming an existing file creates a renamed record and keeps the old path in the detail view."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已存在文件重新命名會產生重新命名記錄，並在詳情中保留原路徑。"
          }
        }
      }
    },
    "如果是刚新建的文件又重命名，应用会合并为最终路径的一条新增记录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If a newly created file is renamed before sync, the app merges it into one created record at the final path."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果是剛新建的文件又重新命名，應用會合併為最終路徑的一條新增記錄。"
          }
        }
      }
    },
    "快速新建后删除": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create Then Delete Quickly"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速新建後刪除"
          }
        }
      }
    },
    "未同步前创建又删除会被视为一次无效临时变动。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creating and deleting before sync is treated as a temporary no-op change."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未同步前建立又刪除會被視為一次無效臨時變動。"
          }
        }
      }
    },
    "适合过滤编辑器临时文件和误操作，不会增加角标或通知。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This helps filter editor temporary files and accidental operations without increasing badges or notifications."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "適合過濾編輯器臨時文件和誤操作，不會增加角標或通知。"
          }
        }
      }
    },
    "点击单条“同步到 IMA”或首页“全部同步”后才上传。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uploads only after you click “Sync to IMA” for one record or “Sync All” on the home page."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊單條「同步到 IMA」或首頁「全部同步」後才上傳。"
          }
        }
      }
    },
    "这是默认模式，适合确认后再同步。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is the default mode and is best when you want to review changes first."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這是預設模式，適合確認後再同步。"
          }
        }
      }
    },
    "开启后，文件变动稳定 30 秒再上传到绑定知识库。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, changes upload to the bound knowledge base after staying stable for 30 seconds."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，文件變動穩定 30 秒再上傳到綁定知識庫。"
          }
        }
      }
    },
    "频繁保存会重置等待时间，避免上传半成品。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Frequent saves reset the wait time to avoid uploading half-finished files."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "頻繁儲存會重置等待時間，避免上傳半成品。"
          }
        }
      }
    },
    "忽略规则会先于记录入库执行；被忽略的文件不会产生记录、通知、角标或同步任务。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignore rules run before records are saved. Ignored files do not create records, notifications, badges, or sync tasks."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "忽略規則會先於記錄入庫執行；被忽略的文件不會產生記錄、通知、角標或同步任務。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
