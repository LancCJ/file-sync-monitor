    "过滤 .DS_Store、临时文件、系统目录和常见构建缓存": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Filters .DS_Store, temporary files, system folders, and common build caches."
          }
        },
        "zh-Hant": {
