    "按功能场景查看 FileSyncMonitor 的监控、同步、导出与设置能力。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore FileSyncMonitor by workflow: monitoring, sync, export, and settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按功能场景查看 FileSyncMonitor 的监控、同步、导出与设置能力。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按功能場景查看 FileSyncMonitor 的監控、同步、匯出與設定能力。"
          }
        }
      }
    },
    "清新、轻量、面向日常同步工作流。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fresh, lightweight, and built for everyday sync workflows."
          }
        },
        "zh-Hans": {
