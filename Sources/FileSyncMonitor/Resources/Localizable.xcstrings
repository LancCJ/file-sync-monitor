            "value": "Filters .DS_Store, temporary files, system folders, build outputs, and common caches by default."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认过滤 .DS_Store、临时文件、系统目录、构建产物和常见缓存目录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "預設過濾 .DS_Store、暫存檔、系統目錄、建置產物和常見快取目錄。"
          }
        }
      }
    },
