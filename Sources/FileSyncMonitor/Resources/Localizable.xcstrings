    "极致视觉反馈": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visual Feedback"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "極致視覺回馈"
          }
        }
      }
    },
    "每一处按钮与卡片都经过精心调校，支持细腻的悬停动效与平滑的状态转换。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every button and card is carefully tuned, supporting subtle hover effects and smooth state transitions."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每一處按鈕与卡片都經過精心調校，支持細膩的懸停動效与平滑的狀態轉換。"
          }
        }
      }
    },
    "秒级记录分析": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Second-Level Analytics"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
