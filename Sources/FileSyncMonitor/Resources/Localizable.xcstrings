    },
    "支持秒级精度的时间轴回溯，并提供专业级 CSV/JSON 报表导出。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Supports second-level precision timeline backtracking and provides professional CSV/JSON report export."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "支持秒級精度的時間軸回溯，並提供專業級 CSV/JSON 報表導出。"
          }
        }
      }
    },
