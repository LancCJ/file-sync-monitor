          }
        }
      }
    },
    "点击“添加目录”选择你要关注的文件夹。授权后，文件新增、修改、删除和重命名都会被自动记录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click “Add Folder” and choose a folder to watch. After permission is granted, created, modified, deleted, and renamed files are recorded automatically."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击“添加目录”选择你要关注的文件夹。授权后，文件新增、修改、删除和重命名都会被自动记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊「新增目錄」選擇你要關注的資料夾。授權後，檔案新增、修改、刪除和重新命名都會被自動記錄。"
          }
        }
      }
    },
    "选择手动或自动同步": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose manual or auto sync"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择手动或自动同步"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇手動或自動同步"
          }
        }
      }
    },
    "默认是手动同步。开启自动同步后，文件稳定 30 秒会自动上传到 IMA，适合持续写作或频繁保存的目录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manual sync is the default. Turn on auto sync and files upload to IMA after staying stable for 30 seconds, which is useful for frequent saves."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认是手动同步。开启自动同步后，文件稳定 30 秒会自动上传到 IMA，适合持续写作或频繁保存的目录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "預設是手動同步。開啟自動同步後，檔案穩定 30 秒會自動上傳到 IMA，適合持續寫作或頻繁保存的目錄。"
          }
        }
      }
    },
    "处理待同步与历史记录": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Handle pending and history"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "处理待同步与历史记录"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "處理待同步與歷史記錄"
          }
        }
      }
    },
    "第二个图标查看待同步队列，第三个图标查看全部记录。你可以搜索、筛选、切换树状视图、同步或清理记录。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the second icon for Pending and the third for All Records. You can search, filter, switch to tree view, sync, or clean records."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "第二个图标查看待同步队列，第三个图标查看全部记录。你可以搜索、筛选、切换树状视图、同步或清理记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "第二個圖示查看待同步佇列，第三個圖示查看全部記錄。你可以搜尋、篩選、切換樹狀視圖、同步或清理記錄。"
          }
        }
      }
    },
    "最后配置云端和偏好": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure cloud and preferences"
          }
