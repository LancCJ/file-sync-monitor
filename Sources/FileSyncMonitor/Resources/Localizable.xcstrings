            "state": "translated",
            "value": "复制 API Key"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "複製 API Key"
          }
        }
      }
    },
    "继续复制 API Key，粘贴到 API Key 输入框。API Key 属于敏感凭据，请不要发给他人或提交到代码仓库。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy API Key and paste it into the API Key field. API Key is sensitive, so do not share it or commit it to a repository."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续复制 API Key，粘贴到 API Key 输入框。API Key 属于敏感凭据，请不要发给他人或提交到代码仓库。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "繼續複製 API Key，貼到 API Key 輸入框。API Key 屬於敏感憑證，請不要發給他人或提交到程式碼倉庫。"
          }
        }
      }
    },
    "点击“测试连接”。如果连接成功，应用会获取 IMA 知识库列表，并允许你给监控目录绑定目标知识库。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click “Test Connection”. If successful, the app fetches IMA knowledge bases and lets you bind folders to targets."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击“测试连接”。如果连接成功，应用会获取 IMA 知识库列表，并允许你给监控目录绑定目标知识库。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊「測試連線」。如果連線成功，應用會取得 IMA 知識庫列表，並允許你給監控目錄綁定目標知識庫。"
          }
        }
      }
    },
    "凭据失效时重新生成": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Regenerate if credentials expire"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "凭据失效时重新生成"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "憑證失效時重新生成"
          }
        }
      }
    },
    "如果测试失败，请确认账号是否登录正确、凭据是否完整；必要时回到 IMA 页面重新生成或复制新的凭据。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the test fails, confirm the account and credentials are correct; regenerate or copy new credentials from IMA if needed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果测试失败，请确认账号是否登录正确、凭据是否完整；必要时回到 IMA 页面重新生成或复制新的凭据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果測試失敗，請確認帳號是否登入正確、憑證是否完整；必要時回到 IMA 頁面重新生成或複製新的憑證。"
          }
        }
      }
    },
    "支持开源项目": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Support the Open Source Project"
          }
        },
        "zh-Hans": {
