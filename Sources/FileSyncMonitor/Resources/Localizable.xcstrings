    },
    "第一步：添加监控目录": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step 1: Add a monitored folder"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
