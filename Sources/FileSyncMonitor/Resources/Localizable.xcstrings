            "value": "Help"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "幫助"
          }
        }
      }
    },
    "帮助与关于": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Help & About"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "幫助與关于"
          }
        }
      }
    },
    "解锁 FileSyncMonitor 的全部潜力，让您的工作流与 IMA 云端无缝合一。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock the full potential of FileSyncMonitor and seamlessly integrate your workflow with IMA Cloud."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "解鎖 FileSyncMonitor 的全部潛力，讓您的工作流與 IMA 雲端無縫合一。"
          }
        }
      }
    },
    "实时智能监控": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Intelligent Monitoring"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "實時智能監控"
          }
        }
      }
    },
    "全天候变动捕获": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "24/7 Change Capture"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "全天候變動捕獲"
          }
        }
      }
    },
    "利用高性能 FSEvents 技术，秒级感知任何文件的新增、修改或重命名。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Using high-performance FSEvents technology to sense any file creation, modification, or renaming in seconds."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "利用高性能 FSEvents 技術，秒級感知任何文件的新增、修改或重命名。"
          }
        }
      }
    },
    "智能过滤引擎": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Smart Filter Engine"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "智能過濾引擎"
          }
        }
      }
    },
    "内置专业级忽略规则，自动屏蔽缓存与系统杂质，让您的监控列表始终保持纯净。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built-in professional-grade ignore rules automatically block cache and system noise, keeping your monitor list clean."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "內置專業級忽略規則，自動屏蔽緩存与系統雜質，讓您的監控列表始終保持純潔。"
          }
        }
      }
    },
    "IMA 双向同步": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "IMA Bidirectional Sync"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "IMA 雙向同步"
          }
        }
      }
    },
    "双向拉取与删除决策": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bidirectional Pull & Deletion Decision"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雙向拉取與刪除決策"
          }
        }
      }
    },
    "点击「从云端拉取更新」以合并云端更改。若本地已被删除的文件仍存于云端，会弹框提示您选择重新拉回或保持本地删除。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click 'Pull from Cloud' to merge cloud changes. If locally deleted files still exist on the cloud, a dialog will ask whether you want to pull them back or keep them deleted."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊「從雲端拉取更新」以合併雲端更改。若本地已被刪除的文件仍存於雲端，會彈框提示您選擇重新拉回或保持本地刪除。"
          }
        }
      }
    },
    "自动推送与删除同步": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto Push & Deletion Sync"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動推送與刪除同步"
          }
        }
      }
    },
    "开启自动同步后 30 秒自动完成云端备份。对于本地删除事件，应用会自动标记同步成功，并指引您手动清理云端以实现双向一致。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto backup completes 30 seconds after saving. For local deletion events, the app automatically marks them synced and guides you to manually clean the cloud for full consistency."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟自動同步後 30 秒自動完成雲端備份。對於本地刪除事件，應用會自動標記同步成功，並指引您手動清理雲端以實現雙向一致。"
          }
        }
      }
    },
    "精品化交互体验": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium UX Design"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "精品化交互體驗"
          }
        }
