    "保留所有已同步和未同步记录，适合回溯历史、查找文件变动轨迹。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keeps synced and unsynced records for history review and change tracing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留所有已同步和未同步记录，适合回溯历史、查找文件变动轨迹。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保留所有已同步和未同步記錄，適合回溯歷史、查找檔案變動軌跡。"
          }
        }
      }
    },
    "列表与树状模式": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "List & Tree Modes"
          }
        },
