          }
        }
      }
    },
    "本地删除会在应用内标记已同步；由于 IMA 未开放云端删除 API，云端文档需手动清理。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local deletions are marked synced in the app. Since IMA has no cloud delete API, cloud documents require manual cleanup."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地删除会在应用内标记已同步；由于 IMA 未开放云端删除 API，云端文档需手动清理。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本地刪除會在應用內標記已同步；由於 IMA 未開放雲端刪除 API，雲端文件需手動清理。"
          }
        }
      }
    },
    "请求日志排查": {
      "localizations": {
