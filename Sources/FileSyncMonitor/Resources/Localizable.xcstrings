      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Help & About" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "幫助與关于" } }
      }
    },
    "解锁 FileSyncMonitor 的全部潜力，让您的工作流与 IMA 云端无缝合一。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Unlock the full potential of FileSyncMonitor and seamlessly integrate your workflow with IMA Cloud." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "解鎖 FileSyncMonitor 的全部潛力，讓您的工作流與 IMA 雲端無縫合一。" } }
      }
    },
    "实时智能监控" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Intelligent Monitoring" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "實時智能監控" } }
      }
    },
    "全天候变动捕获" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "24/7 Change Capture" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "全天候變動捕獲" } }
      }
    },
    "利用高性能 FSEvents 技术，秒级感知任何文件的新增、修改或重命名。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Using high-performance FSEvents technology to sense any file creation, modification, or renaming in seconds." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "利用高性能 FSEvents 技術，秒級感知任何文件的新增、修改或重命名。" } }
      }
    },
    "智能过滤引擎" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Smart Filter Engine" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "智能過濾引擎" } }
      }
    },
    "内置专业级忽略规则，自动屏蔽缓存与系统杂质，让您的监控列表始终保持纯净。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Built-in professional-grade ignore rules automatically block cache and system noise, keeping your monitor list clean." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "內置專業級忽略規則，自動屏蔽緩存与系統雜質，讓您的監控列表始終保持純潔。" } }
      }
    },
    "IMA 双向同步" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "IMA Bidirectional Sync" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "IMA 雙向同步" } }
      }
    },
    "双向拉取尝试" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Bidirectional Pull" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "雙向拉取嘗試" } }
      }
    },
    "点击「从云端拉取更新」，即可智能识别并下载知识库中的新文件到本地。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Click 'Pull from Cloud' to intelligently identify and download new files from the knowledge base to local." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "點擊「從雲端拉取更新」，即可智能識別並下載知識庫中的新文件到本地。" } }
      }
    },
    "自动化推送流程" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Automated Push Flow" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "自動化推送流程" } }
      }
    },
    "开启自动同步后，应用会在您保存文件 30 秒后自动完成云端备份。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "With auto-sync enabled, the app will automatically back up to the cloud 30 seconds after you save a file." } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "開啟自動同步後，應用會在您保存文件 30 秒後自動完成雲端備份。" } }
      }
    },
    "精品化交互体验" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Premium UX Design" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "精品化交互體驗" } }
      }
    },
    "极致视觉反馈" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Visual Feedback" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "極致視覺回馈" } }
      }
    },
    "每一处按钮与卡片都经过精心调校，支持细腻的悬停动效与平滑的状态转换。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Every button and card is carefully tuned, supporting subtle hover effects and smooth state transitions." } },
